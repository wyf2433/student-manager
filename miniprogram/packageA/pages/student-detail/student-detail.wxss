.detail-avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.detail-info {
  display: flex;
  flex-direction: column;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.detail-meta {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.quick-action-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.quick-action-circle {
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.sticky-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.note-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.note-item:last-child {
  border-bottom: none;
}

.note-content {
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.6;
  display: block;
  margin-bottom: 4rpx;
}

.note-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.score-group {
  margin-bottom: 20rpx;
}

.score-group:last-child { margin-bottom: 0; }

.score-group-header {
  font-size: 26rpx;
  font-weight: 700;
  color: #4B5563;
  margin-bottom: 12rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #6366F1;
}

.score-subject-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.score-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #F9FAFB;
  border: 1rpx solid #F3F4F6;
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  min-width: 120rpx;
}

.score-chip-name {
  font-size: 22rpx;
  color: #9CA3AF;
}

.score-chip-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #6366F1;
  margin-top: 4rpx;
}

.score-chip-full {
  font-size: 20rpx;
  font-weight: 400;
  color: #D1D5DB;
}

/* 底部弹窗 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx;
  z-index: 1001;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.action-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-close {
  font-size: 32rpx;
  color: #9CA3AF;
  font-weight: 400;
}

.action-body {
  margin-top: 8rpx;
}

.action-save-btn {
  width: 100% !important;
  margin-top: 16rpx;
}

/* 成绩趋势 ECharts */
.trend-subject-pick {
  font-size: 24rpx;
  color: #6366F1;
  font-weight: 600;
  background: #EEF2FF;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.trend-chart-container {
  width: 100%;
  height: 400rpx;
  margin: 16rpx 0;
}

.trend-chart-container ec-canvas {
  width: 100%;
  height: 100%;
}

/* 趋势详情列表 */
.trend-detail-list {
  margin-top: 16rpx;
}

.trend-detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.trend-detail-item:last-child { border-bottom: none; }

.trend-detail-info {
  display: flex;
  flex-direction: column;
}

.trend-detail-exam {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.trend-detail-subject {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.trend-detail-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.trend-detail-score {
  font-size: 32rpx;
  font-weight: 800;
  color: #6366F1;
}

.trend-detail-avg {
  font-size: 22rpx;
  color: #9CA3AF;
}

.delete-student-btn {
  text-align: center;
  font-size: 28rpx;
  color: #EF4444;
  padding: 24rpx;
  margin: 24rpx 0;
  background: #FEF2F2;
  border-radius: 16rpx;
  font-weight: 600;
}

.delete-student-btn:active {
  opacity: 0.7;
}
