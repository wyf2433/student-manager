.detail-avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.detail-info {
  display: flex;
  flex-direction: column;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.detail-meta {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.quick-action-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.quick-action-circle {
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.sticky-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.note-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.note-item:last-child {
  border-bottom: none;
}

.note-content {
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.6;
  display: block;
  margin-bottom: 4rpx;
}

.note-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.score-group {
  margin-bottom: 20rpx;
}

.score-group:last-child { margin-bottom: 0; }

.score-group-header {
  font-size: 26rpx;
  font-weight: 700;
  color: #4B5563;
  margin-bottom: 12rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #6366F1;
}

.score-subject-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.score-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #F9FAFB;
  border: 1rpx solid #F3F4F6;
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  min-width: 120rpx;
}

.score-chip-name {
  font-size: 22rpx;
  color: #9CA3AF;
}

.score-chip-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #6366F1;
  margin-top: 4rpx;
}

.score-chip-full {
  font-size: 20rpx;
  font-weight: 400;
  color: #D1D5DB;
}

/* 底部弹窗 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx;
  z-index: 1001;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.action-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-close {
  font-size: 32rpx;
  color: #9CA3AF;
  font-weight: 400;
}

.action-body {
  margin-top: 8rpx;
}

.action-save-btn {
  width: 100% !important;
  margin-top: 16rpx;
}

/* 成绩趋势 纯CSS折线图 */
.trend-subject-pick {
  font-size: 24rpx;
  color: #6366F1;
  font-weight: 600;
  background: #EEF2FF;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.css-chart {
  margin: 20rpx 0 8rpx;
}

.css-chart-area {
  position: relative;
  height: 280rpx;
  margin: 0 16rpx;
}

.css-grid {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: #F3F4F6;
}

.css-grid-top { top: 0; }
.css-grid-mid { top: 50%; background: #E5E7EB; }
.css-grid-bot { bottom: 0; }

.css-full-label {
  position: absolute;
  top: -10rpx;
  right: 0;
  font-size: 20rpx;
  color: #D1D5DB;
}

.css-line {
  position: absolute;
  height: 4rpx;
  background: #6366F1;
  transform-origin: left center;
  border-radius: 2rpx;
  z-index: 1;
}

.css-line-class {
  height: 2rpx;
  background: #D1D5DB;
  border-radius: 1rpx;
}

.css-point {
  position: absolute;
  transform: translateX(-50%);
  z-index: 2;
}

.css-point-class {
  transform: translateX(-50%) translateY(50%);
}

.css-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 0 0 2rpx currentColor;
}

.css-dot-student {
  background: #6366F1;
  color: #6366F1;
}

.css-dot-class {
  width: 16rpx;
  height: 16rpx;
  background: #D1D5DB;
  color: #D1D5DB;
}

.css-label {
  position: absolute;
  bottom: 28rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  font-weight: 700;
  color: #6366F1;
  white-space: nowrap;
}

.css-x-axis {
  position: relative;
  height: 56rpx;
  margin-top: 8rpx;
}

.css-x-label {
  position: absolute;
  transform: translateX(-50%);
  text-align: center;
  max-width: 180rpx;
}

.css-x-exam {
  font-size: 22rpx;
  font-weight: 600;
  color: #4B5563;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.css-x-date {
  font-size: 20rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 2rpx;
}

.css-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin: 12rpx 0 16rpx;
}

.css-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #6B7280;
}

.css-legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.css-legend-dot.css-dot-student { background: #6366F1; }
.css-legend-dot.css-dot-class { background: #D1D5DB; }

/* 趋势详情列表 */
.trend-detail-list {
  margin-top: 16rpx;
}

.trend-detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.trend-detail-item:last-child { border-bottom: none; }

.trend-detail-info {
  display: flex;
  flex-direction: column;
}

.trend-detail-exam {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.trend-detail-subject {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.trend-detail-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.trend-detail-score {
  font-size: 32rpx;
  font-weight: 800;
  color: #6366F1;
}

.trend-detail-avg {
  font-size: 22rpx;
  color: #9CA3AF;
}
