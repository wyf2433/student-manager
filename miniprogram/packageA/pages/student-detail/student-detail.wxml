<view class="container" wx:if="{{student}}">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." inherit />

  <block wx:if="{{!loading}}">
    <!-- 渐变信息卡 -->
    <view class="gradient-header-large">
      <view class="detail-avatar-row">
        <view class="avatar-grad avatar-grad-{{avatarIdx}}" style="width: 120rpx; height: 120rpx; font-size: 52rpx; border: 4rpx solid rgba(255,255,255,0.3);">
          {{student.name[0]}}
        </view>
        <view class="detail-info">
          <text class="detail-name">{{student.name}}</text>
          <text class="detail-meta">{{student.student_no || '无学号'}}</text>
        </view>
      </view>
      <!-- 快速操作 -->
      <view class="quick-actions">
        <view class="quick-action-item" bindtap="quickAction" data-type="attendance">
          <view class="quick-action-circle qa-green">📅</view>
          <text class="quick-action-text">考勤</text>
        </view>
        <view class="quick-action-item" bindtap="quickAction" data-type="leave">
          <view class="quick-action-circle qa-orange">🚪</view>
          <text class="quick-action-text">请假</text>
        </view>
        <view class="quick-action-item" bindtap="quickAction" data-type="score">
          <view class="quick-action-circle qa-red">⭐</view>
          <text class="quick-action-text">加扣分</text>
        </view>
      </view>
    </view>

    <!-- 个人备注 -->
    <view class="card">
      <view class="card-title">💬 个人备注</view>
      <view class="sticky-note sticky-yellow" style="margin-bottom: 16rpx;">
        <textarea
          class="sticky-note-input"
          placeholder="记录关于这个学生的情况..."
          value="{{noteContent}}"
          bindinput="onNoteInput"
          maxlength="500"
          auto-height
        />
        <view class="sticky-actions">
          <t-button theme="primary" size="small" bindtap="saveNote">记录 ✏️</t-button>
        </view>
      </view>
      <view wx:if="{{notes.length === 0}}" class="empty">
        <text class="empty-emoji">📭</text>
        <text>暂无备注</text>
      </view>
      <t-swipe-cell
        wx:for="{{notes}}"
        wx:key="id"
        right="{{[{text: '删除', className: 'swipe-delete-btn'}]}}"
        bind:click="deleteNoteSwipe"
        data-id="{{item.id}}"
      >
        <view class="note-item">
          <text class="note-content">{{item.content}}</text>
          <text class="note-time">🕐 {{item.created_at}}</text>
        </view>
      </t-swipe-cell>
    </view>

    <!-- 成绩记录 -->
    <view class="card" wx:if="{{scoreGroups.length > 0}}">
      <view class="card-title">🏆 成绩记录</view>
      <view wx:for="{{scoreGroups}}" wx:key="exam_name" class="score-group">
        <view class="score-group-header">{{item.exam_name}}</view>
        <view class="score-subject-grid">
          <view wx:for="{{item.subjects}}" wx:for-item="sub" wx:key="id" class="score-chip">
            <text class="score-chip-name">{{sub.subject}}</text>
            <text class="score-chip-value">{{sub.score}}<text class="score-chip-full">/{{sub.full_score}}</text></text>
          </view>
        </view>
      </view>
    </view>

    <!-- 成绩趋势 -->
    <view class="card" wx:if="{{trendExams.length > 0}}">
      <view class="card-title-row">
        <text class="card-title">📈 成绩趋势</text>
        <picker wx:if="{{trendSubjects.length > 1}}" range="{{trendSubjects}}" bindchange="onTrendSubjectChange">
          <view class="trend-subject-pick">📖 {{currentSubject}} ›</view>
        </picker>
      </view>

      <!-- 纯CSS折线图 -->
      <view class="css-chart" wx:if="{{chartData}}">
        <view class="css-chart-area">
          <view class="css-grid css-grid-top"></view>
          <view class="css-grid css-grid-mid"></view>
          <view class="css-grid css-grid-bot"></view>

          <view class="css-full-label">满分{{chartData.fullScore}}</view>

          <!-- 连线 -->
          <view wx:for="{{chartData.lines}}" wx:key="index"
            class="css-line {{item.isClass ? 'css-line-class' : ''}}"
            style="left: {{item.left}}%; top: {{item.top}}%; width: {{item.length}}%; transform: rotate({{item.angle}}deg);">
          </view>

          <!-- 数据点 -->
          <block wx:for="{{chartData.points}}" wx:key="exam_name">
            <view class="css-point" style="left: {{item.xPercent}}%; bottom: {{item.yPercent}}%;">
              <view class="css-dot css-dot-student"></view>
              <text class="css-label">{{item.score}}</text>
            </view>
            <view wx:if="{{item.classYPercent !== null}}" class="css-point css-point-class" style="left: {{item.xPercent}}%; bottom: {{item.classYPercent}}%;">
              <view class="css-dot css-dot-class"></view>
            </view>
          </block>
        </view>

        <!-- X轴标签 -->
        <view class="css-x-axis">
          <view wx:for="{{chartData.xLabels}}" wx:key="exam_name" class="css-x-label" style="left: {{item.xPercent}}%;">
            <text class="css-x-exam">{{item.exam_name}}</text>
            <text class="css-x-date">{{item.date}}</text>
          </view>
        </view>

        <!-- 图例 -->
        <view class="css-legend">
          <view class="css-legend-item"><view class="css-legend-dot css-dot-student"></view><text>本人成绩</text></view>
          <view class="css-legend-item" wx:if="{{chartData.hasClassAvg}}"><view class="css-legend-dot css-dot-class"></view><text>班级均分</text></view>
        </view>
      </view>

      <!-- 趋势详情列表 -->
      <view class="trend-detail-list">
        <view wx:for="{{trendExams}}" wx:key="exam_name" class="trend-detail-item">
          <view class="trend-detail-info">
            <text class="trend-detail-exam">{{item.exam_name}}</text>
            <text class="trend-detail-subject">{{item.subject}} · {{item.date}}</text>
          </view>
          <view class="trend-detail-right">
            <text class="trend-detail-score">{{item.score}}分</text>
            <text class="trend-detail-avg" wx:if="{{item.class_avg}}">班均{{item.class_avg}}</text>
            <view wx:if="{{item.changeLabel}}" class="color-tag {{item.changeClass}}">
              {{item.changeLabel}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 记录时间线 -->
    <view class="card">
      <view class="card-title">📋 记录时间线</view>
      <view wx:if="{{records.length === 0}}" class="empty">
        <text class="empty-emoji">📭</text>
        <text>暂无记录</text>
      </view>
      <view class="timeline" wx:if="{{records.length > 0}}">
        <view wx:for="{{records}}" wx:key="id" class="timeline-item">
          <view class="timeline-dot {{item.dotClass}}"></view>
          <view class="timeline-content">
            <view class="timeline-header">
              <view class="color-tag {{item.tagClass}}">
                {{item.emoji}} {{typeLabels[item.type]}}
              </view>
              <text class="timeline-time">{{item.created_at}}</text>
            </view>
            <text class="timeline-desc">{{item.content || ''}}</text>
            <text class="timeline-value" wx:if="{{item.value !== null && item.value !== undefined}}">
              {{item.value > 0 ? '+' : ''}}{{item.value}}分
            </text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>

<!-- 底部弹窗: 快速记录 -->
<view class="action-mask" wx:if="{{showAction}}" bindtap="closeAction"></view>
<view class="action-sheet" wx:if="{{showAction}}">
  <view class="action-title">
    {{actionType === 'attendance' ? '📅 记考勤' : actionType === 'leave' ? '🚪 记请假' : '⭐ 加扣分'}}
    <text class="action-close" bindtap="closeAction">✕</text>
  </view>
  <view class="action-body">
    <view class="form-item" wx:if="{{actionType === 'score'}}">
      <text class="form-label">分数</text>
      <input class="form-input" type="digit" placeholder="正数加分,负数扣分" value="{{actionValue}}" bindinput="onActionValueInput" />
    </view>
    <view class="form-item">
      <text class="form-label">{{actionType === 'leave' ? '事由' : '描述'}}</text>
      <textarea class="form-textarea" placeholder="输入描述..." value="{{actionContent}}" bindinput="onActionContentInput" maxlength="500" auto-height />
    </view>
    <t-button theme="primary" size="large" bindtap="saveAction" loading="{{saving}}" t-class="action-save-btn">
      保存
    </t-button>
  </view>
</view>
