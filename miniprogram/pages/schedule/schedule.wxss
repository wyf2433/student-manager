.weekday-tabs {
  margin-bottom: 20rpx;
}

.schedule-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.schedule-emoji {
  font-size: 40rpx;
  flex-shrink: 0;
}

.schedule-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.schedule-subject {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
}

.schedule-class {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.bottom-bar {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
  z-index: 100;
}

.btn-outline.warn {
  background: #fff;
  color: #F59E0B;
  border: 2rpx solid #FDE68A;
  border-radius: 32rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.fab {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(102,126,234,0.4);
}
