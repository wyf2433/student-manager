.weekday-tabs {
  margin-bottom: 20rpx;
}

.schedule-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.schedule-emoji {
  font-size: 40rpx;
  flex-shrink: 0;
}

.schedule-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.schedule-subject {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
}

.schedule-class {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.bottom-bar {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
  z-index: 100;
}
