<view class="container">
  <t-tabs value="{{currentWeekday}}" bindchange="onWeekdayChange" t-class="weekday-tabs">
    <t-tab-panel wx:for="{{weekdays}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" />
  </t-tabs>

  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." inherit />

  <block wx:if="{{!loading}}">
    <view wx:if="{{schedules.length === 0}}" class="empty">
      <text class="empty-emoji">🎉</text>
      <text>暂无课程,点击右下角添加</text>
    </view>
    <t-swipe-cell
      wx:for="{{schedules}}"
      wx:key="id"
      right="{{[{text: '删除', className: 'swipe-delete-btn'}]}}"
      bind:click="onDeleteSwipe"
      data-id="{{item.id}}"
    >
      <view class="card card-bar bar-blue" bindtap="goEdit" data-id="{{item.id}}">
        <view class="schedule-row">
          <text class="schedule-emoji">{{item.emoji}}</text>
          <view class="schedule-detail">
            <text class="schedule-subject">{{item.subject}}</text>
            <text class="schedule-class">第{{item.period}}节{{item.class_name ? ' · ' + item.class_name : ''}}</text>
          </view>
          <view class="color-tag tag-blue">第{{item.period}}节</view>
        </view>
      </view>
    </t-swipe-cell>
  </block>
</view>

<view class="bottom-bar">
  <view class="btn-outline warn" bindtap="goOverride">🔀 临时调课</view>
  <view class="schedule-add-btn" bindtap="goAdd">+</view>
</view>
