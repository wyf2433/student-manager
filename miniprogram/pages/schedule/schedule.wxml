<view class="container">
  <!-- 星期选择 -->
  <scroll-view class="weekday-tabs" scroll-x>
    <view
      wx:for="{{weekdays}}"
      wx:key="value"
      class="weekday-tab {{currentWeekday === item.value ? 'active' : ''}}"
      bindtap="onWeekdayTap"
      data-weekday="{{item.value}}"
    >
      {{item.label}}
    </view>
  </scroll-view>

  <!-- 课表列表 -->
  <view wx:if="{{schedules.length === 0 && !loading}}" class="empty">暂无课程,点击右下角添加</view>
  <view wx:for="{{schedules}}" wx:key="id" class="schedule-card">
    <view class="schedule-card-main" bindtap="goEdit" data-id="{{item.id}}">
      <view class="schedule-period-tag">第{{item.period}}节</view>
      <view class="schedule-detail">
        <text class="schedule-subject">{{item.subject}}</text>
        <text class="schedule-class" wx:if="{{item.class_name}}">{{item.class_name}}</text>
      </view>
    </view>
    <text class="delete-btn" bindtap="onDelete" data-id="{{item.id}}">删除</text>
  </view>
</view>

<!-- 底部按钮 -->
<view class="bottom-bar">
  <view class="btn-override" bindtap="goOverride">临时调课</view>
  <view class="fab" bindtap="goAdd">+</view>
</view>
