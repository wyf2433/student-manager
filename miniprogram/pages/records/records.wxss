.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.record-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.record-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-student {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.record-desc {
  font-size: 26rpx;
  color: #6B7280;
}

.record-value {
  font-size: 32rpx;
  font-weight: 800;
  color: #EF4444;
}
