.filter-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.filter-tab.active {
  background: #3282F0;
  color: #fff;
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.record-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  color: #fff;
}

.type-attendance {
  background: #52C41A;
}

.type-leave {
  background: #FAAD14;
}

.type-score {
  background: #FF4D4F;
}

.record-time {
  font-size: 22rpx;
  color: #BBB;
}

.record-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-student {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.record-desc {
  font-size: 26rpx;
  color: #666;
}

.record-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF4D4F;
}

.record-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #FF4D4F;
  padding: 8rpx 20rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #3282F0;
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(50, 130, 240, 0.4);
}

.fab:active {
  background: #2870D0;
}
