<view class="container">
  <t-tabs value="{{filterType}}" bindchange="onFilterChange" t-class="filter-tabs">
    <t-tab-panel wx:for="{{typeFilters}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" />
  </t-tabs>

  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." inherit />

  <block wx:if="{{!loading}}">
    <view wx:if="{{records.length === 0}}" class="empty">
      <text class="empty-emoji">📭</text>
      <text>暂无记录</text>
    </view>
    <t-swipe-cell
      wx:for="{{records}}"
      wx:key="id"
      right="{{[{text: '删除', className: 'swipe-delete-btn'}]}}"
      bind:click="onDeleteSwipe"
      data-id="{{item.id}}"
    >
      <view class="card card-bar {{item.barClass}}">
        <view class="record-header">
          <view class="color-tag {{item.tagClass}}">
            {{item.emoji}} {{typeLabels[item.type]}}
          </view>
          <text class="record-time">🕐 {{item.created_at}}</text>
        </view>
        <view class="record-body">
          <text class="record-student">学生ID: {{item.student_id}}</text>
          <text class="record-desc" wx:if="{{item.content}}">{{item.content}}</text>
          <text class="record-value" wx:if="{{item.value !== null && item.value !== undefined}}">{{item.value > 0 ? '+' : ''}}{{item.value}}分</text>
        </view>
      </view>
    </t-swipe-cell>
  </block>
</view>

<view class="fab" bindtap="goAdd">+</view>
