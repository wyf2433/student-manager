.upload-area {
  border: 2rpx dashed #C7D2FE;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background: #F5F3FF;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #9CA3AF;
  font-size: 26rpx;
}

.upload-icon {
  font-size: 56rpx;
  color: #C7D2FE;
  margin-bottom: 8rpx;
}

.uploading {
  color: #6366F1;
  font-size: 28rpx;
}

.file-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.file-name {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 700;
}

.file-change {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.format-desc {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.format-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-start;
}

.tip-text {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
}

/* 满分输入列表 */
.full-score-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.full-score-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
}

.full-score-subject {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
}

.full-score-input {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #6366F1;
  background: #fff;
  border-radius: 8rpx;
  padding: 8rpx 0;
}

.full-score-unit {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 预览表格 */
.preview-table {
  min-width: 100%;
}

.preview-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
  white-space: nowrap;
}

.preview-header-row {
  border-bottom: 2rpx solid #E5E7EB;
}

.preview-cell {
  min-width: 140rpx;
  font-size: 26rpx;
  color: #1F2937;
  padding: 0 12rpx;
}

.preview-header-row .preview-cell {
  font-weight: 700;
  color: #9CA3AF;
  font-size: 24rpx;
}

.save-btn {
  margin: 40rpx 0;
  border-radius: 16rpx;
}

.save-btn.disabled {
  opacity: 0.5;
}
