.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.form-picker {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.form-empty {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #BBB;
}

.upload-area {
  border: 2rpx dashed #CCC;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 26rpx;
}

.upload-icon {
  font-size: 56rpx;
  color: #CCC;
  margin-bottom: 8rpx;
}

.uploading {
  color: #3282F0;
  font-size: 28rpx;
}

.file-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.file-change {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.format-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.format-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.format-item {
  font-size: 26rpx;
  color: #3282F0;
}

.preview-header {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #EEE;
}

.preview-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.preview-cell {
  flex: 1;
  font-size: 28rpx;
}

.preview-header .preview-cell {
  font-weight: 600;
  color: #999;
  font-size: 26rpx;
}

.save-btn {
  margin: 40rpx 0;
}

.save-btn.disabled {
  opacity: 0.6;
}

.btn-cancel-text {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 20rpx;
}
