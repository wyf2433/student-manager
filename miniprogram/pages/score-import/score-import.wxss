.upload-area {
  border: 2rpx dashed #C7D2FE;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background: #F5F3FF;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #9CA3AF;
  font-size: 26rpx;
}

.upload-icon {
  font-size: 56rpx;
  color: #C7D2FE;
  margin-bottom: 8rpx;
}

.uploading {
  color: #6366F1;
  font-size: 28rpx;
}

.file-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.file-name {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 700;
}

.file-change {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.format-desc {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.format-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-start;
}

.tip-text {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
}

.preview-header {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #E5E7EB;
}

.preview-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.preview-cell {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

.preview-header .preview-cell {
  font-weight: 700;
  color: #9CA3AF;
  font-size: 26rpx;
}

.save-btn {
  margin: 40rpx 0;
  border-radius: 16rpx;
}

.save-btn.disabled {
  opacity: 0.5;
}
