<view class="container">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." inherit />

  <block wx:if="{{!loading}}">
    <!-- 渐变问候卡 -->
    <view class="gradient-header">
      <view class="greeting">葛老师好 👋</view>
      <view class="greeting-date">{{todayDate}}</view>
      <view class="greeting-sub">
        <view class="greeting-sub-item">📚 {{scheduleCount}}节课</view>
        <view class="greeting-sub-item">📖 {{homeworkCount}}个作业</view>
      </view>
    </view>

    <!-- 彩色统计网格 -->
    <view class="stat-grid" wx:if="{{overview}}">
      <view class="stat-card stat-green">
        <text class="stat-emoji">✅</text>
        <text class="stat-num">{{overview.attendance_count || 0}}</text>
        <text class="stat-label">考勤</text>
      </view>
      <view class="stat-card stat-orange">
        <text class="stat-emoji">🚪</text>
        <text class="stat-num">{{overview.leave_count || 0}}</text>
        <text class="stat-label">请假</text>
      </view>
      <view class="stat-card stat-red">
        <text class="stat-emoji">⭐</text>
        <text class="stat-num">{{overview.score_count || 0}}</text>
        <text class="stat-label">加扣分</text>
      </view>
      <view class="stat-card stat-purple">
        <text class="stat-emoji">📝</text>
        <text class="stat-num">{{overview.note_count || 0}}</text>
        <text class="stat-label">速记</text>
      </view>
    </view>

    <!-- 今日课程 -->
    <view class="card" bindtap="goSchedule">
      <view class="card-title-row">
        <text class="card-title">📚 今日课程</text>
        <text class="card-more">课表 ›</text>
      </view>
      <view wx:if="{{todaySchedule.length === 0}}" class="empty">
        <text class="empty-emoji">🎉</text>
        <text>今日无课,休息一下吧~</text>
      </view>
      <view wx:for="{{todaySchedule}}" wx:key="period" class="schedule-item {{item.is_overridden ? 'overridden' : ''}}">
        <text class="schedule-emoji">{{item.emoji}}</text>
        <view class="schedule-info">
          <text class="schedule-subject">{{item.subject}}</text>
          <text class="schedule-class">第{{item.period}}节{{item.class_name ? ' · ' + item.class_name : ''}}</text>
        </view>
        <view wx:if="{{item.is_overridden}}" class="color-tag tag-orange">调</view>
      </view>
    </view>

    <!-- 今日作业 -->
    <view class="card" bindtap="goHomework">
      <view class="card-title-row">
        <text class="card-title">📖 今日作业</text>
        <text class="card-more">全部 ›</text>
      </view>
      <view wx:if="{{todayHomework.length === 0}}" class="empty">
        <text class="empty-emoji">📭</text>
        <text>今日未布置作业</text>
      </view>
      <view wx:for="{{todayHomework}}" wx:key="id" class="homework-item">
        <text class="hw-emoji">{{item.emoji}}</text>
        <text class="homework-content">{{item.content}}</text>
        <view class="color-tag {{item.status === 'active' ? 'tag-blue' : item.status === 'collected' ? 'tag-orange' : 'tag-green'}}">
          {{hwStatusLabels[item.status]}}
        </view>
      </view>
    </view>

    <!-- 工作留痕入口 -->
    <view class="card trace-entry-card" bindtap="goTraces">
      <view class="trace-entry-left">
        <text class="trace-entry-emoji">📸</text>
        <view>
          <text class="trace-entry-title">工作留痕</text>
          <text class="trace-entry-desc">课堂纪律 / 实验记录 / 学生谈话 / 家长沟通</text>
        </view>
      </view>
      <text class="trace-entry-arrow">›</text>
    </view>

    <!-- 便利贴速记 -->
    <view class="sticky-note">
      <view class="sticky-title">📝 一句话速记</view>
      <textarea
        class="sticky-note-input"
        placeholder="想到什么就记一笔..."
        value="{{quickNote}}"
        bindinput="onNoteInput"
        maxlength="200"
        auto-height
      />
      <view class="sticky-actions">
        <t-button theme="primary" size="small" bindtap="saveNote">记一笔 ✏️</t-button>
      </view>
    </view>

    <!-- 最近动态 -->
    <view class="card">
      <view class="card-title">🕐 最近动态</view>
      <view wx:if="{{recent.length === 0}}" class="empty">
        <text class="empty-emoji">📭</text>
        <text>暂无记录</text>
      </view>
      <view wx:for="{{recent}}" wx:key="id" class="recent-item">
        <text class="recent-emoji">{{item.emoji}}</text>
        <view class="recent-content">
          <text class="recent-text">{{item.summary}}</text>
          <view class="recent-bottom">
            <view class="color-tag {{item.type === 'attendance' ? 'tag-green' : item.type === 'leave' ? 'tag-orange' : item.type === 'score' ? 'tag-red' : 'tag-purple'}}">
              {{item.type_label}}
            </view>
            <text class="recent-time">{{item.time_label}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
