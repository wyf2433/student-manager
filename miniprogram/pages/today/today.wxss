.schedule-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
  gap: 16rpx;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item.overridden {
  background: #FEF3C7;
  margin: 0 -12rpx;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
}

.schedule-emoji {
  font-size: 36rpx;
  flex-shrink: 0;
}

.schedule-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.schedule-subject {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.schedule-class {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.homework-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
  gap: 12rpx;
}

.homework-item:last-child {
  border-bottom: none;
}

.hw-emoji {
  font-size: 32rpx;
  flex-shrink: 0;
}

.homework-content {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.trace-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FCE7F3 0%, #FED7E4 100%);
}

.trace-entry-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.trace-entry-emoji {
  font-size: 44rpx;
}

.trace-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #9B2C6B;
  display: block;
}

.trace-entry-desc {
  font-size: 22rpx;
  color: #B83280;
  margin-top: 4rpx;
  display: block;
}

.trace-entry-arrow {
  font-size: 40rpx;
  color: #B83280;
}

.score-entry-card {
  background: linear-gradient(135deg, #DBEAFE 0%, #E0E7FF 100%);
}

.score-entry-card .trace-entry-title {
  color: #4338CA;
}

.score-entry-card .trace-entry-desc {
  color: #6366F1;
}

.score-entry-card .trace-entry-arrow {
  color: #6366F1;
}

.sticky-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 12rpx;
}

.sticky-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.recent-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
  gap: 12rpx;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-emoji {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.recent-content {
  flex: 1;
}

.recent-text {
  font-size: 28rpx;
  color: #1F2937;
  display: block;
  margin-bottom: 8rpx;
}

.recent-bottom {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.recent-time {
  font-size: 22rpx;
  color: #9CA3AF;
}
