.overview-grid {
  display: flex;
  justify-content: space-around;
  margin-top: 12rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #0052D9;
}

.overview-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item.overridden {
  background: #FFF7E6;
  margin: 0 -12rpx;
  padding: 20rpx 12rpx;
  border-radius: 12rpx;
}

.schedule-period {
  font-size: 24rpx;
  color: #999;
  width: 100rpx;
  flex-shrink: 0;
}

.schedule-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.schedule-subject {
  font-size: 30rpx;
  font-weight: 600;
  color: #181818;
}

.schedule-class {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.homework-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  gap: 12rpx;
}

.homework-item:last-child {
  border-bottom: none;
}

.homework-content {
  flex: 1;
  font-size: 28rpx;
  color: #181818;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.trace-entry {
  position: relative;
}

.trace-entry-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.quick-note {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: flex-end;
}

.note-input {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.recent-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  gap: 12rpx;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recent-text {
  font-size: 28rpx;
  color: #181818;
}

.recent-time {
  font-size: 22rpx;
  color: #BBB;
  margin-top: 6rpx;
}
