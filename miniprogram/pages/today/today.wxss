.overview-grid {
  display: flex;
  justify-content: space-around;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-more {
  font-size: 24rpx;
  color: #3282F0;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item.overridden {
  background: #FFF7E6;
  margin: 0 -12rpx;
  padding: 16rpx 12rpx;
  border-radius: 8rpx;
}

.schedule-period {
  font-size: 24rpx;
  color: #999;
  width: 100rpx;
  flex-shrink: 0;
}

.schedule-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.schedule-subject {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.schedule-class {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.schedule-tag {
  font-size: 20rpx;
  color: #fff;
  background: #FAAD14;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.homework-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.homework-item:last-child {
  border-bottom: none;
}

.homework-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.homework-type.type-daily {
  background: #3282F0;
}

.homework-type.type-experiment_report {
  background: #52C41A;
}

.homework-type.type-review {
  background: #722ED1;
}

.homework-type.type-exam {
  background: #FF4D4F;
}

.homework-content {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.homework-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.homework-status.status-active {
  background: #E6F7FF;
  color: #3282F0;
}

.homework-status.status-collected {
  background: #FFF7E6;
  color: #FAAD14;
}

.homework-status.status-graded {
  background: #F6FFED;
  color: #52C41A;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #3282F0;
}

.overview-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.quick-note {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.note-input {
  width: 100%;
  min-height: 80rpx;
  padding: 16rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.save-btn {
  width: 200rpx;
  align-self: flex-end;
}

.recent-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  color: #fff;
  background: #3282F0;
}

.recent-type.attendance {
  background: #52C41A;
}

.recent-type.leave {
  background: #FAAD14;
}

.recent-type.score {
  background: #FF4D4F;
}

.recent-type.note {
  background: #3282F0;
}

.recent-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recent-text {
  font-size: 28rpx;
  color: #333;
}

.recent-time {
  font-size: 22rpx;
  color: #BBB;
  margin-top: 6rpx;
}
