.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.form-picker {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.form-input {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-cancel {
  padding: 16rpx 32rpx;
  color: #999;
  font-size: 28rpx;
}

.save-btn {
  padding: 16rpx 48rpx;
}

.save-btn.disabled {
  opacity: 0.6;
}

.override-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.override-item:last-child {
  border-bottom: none;
}

.override-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.override-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.override-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.override-action {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  color: #fff;
}

.action-cancel {
  background: #FF4D4F;
}

.action-change {
  background: #FAAD14;
}

.action-add {
  background: #52C41A;
}

.action-substitute {
  background: #3282F0;
}

.override-period {
  font-size: 26rpx;
  color: #666;
}

.override-detail {
  font-size: 26rpx;
  color: #3282F0;
}

.override-note {
  font-size: 24rpx;
  color: #999;
}

.delete-btn {
  font-size: 24rpx;
  color: #FF4D4F;
  padding: 8rpx 20rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #3282F0;
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(50, 130, 240, 0.4);
}

.fab:active {
  background: #2870D0;
}
