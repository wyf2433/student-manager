.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.override-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.override-item:last-child {
  border-bottom: none;
}

.override-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.override-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.override-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #181818;
}

.override-period {
  font-size: 26rpx;
  color: #666;
}

.override-detail {
  font-size: 26rpx;
  color: #0052D9;
}

.override-note {
  font-size: 24rpx;
  color: #999;
}

.swipe-delete-btn {
  background: #D54941 !important;
}
