.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
}

.override-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.override-item:last-child {
  border-bottom: none;
}

.override-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.override-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.override-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #1F2937;
}

.override-period {
  font-size: 26rpx;
  color: #6B7280;
}

.override-detail {
  font-size: 26rpx;
  color: #3B82F6;
  font-weight: 600;
}

.override-note {
  font-size: 24rpx;
  color: #9CA3AF;
}
