<view class="container">
  <!-- 调课表单 -->
  <view class="card" wx:if="{{showForm}}">
    <view class="card-title">新增调课</view>

    <view class="form-item">
      <text class="form-label">日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="form-picker">{{date}} ›</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">节次</text>
      <picker range="{{['第1节','第2节','第3节','第4节','第5节','第6节','第7节','第8节','第9节','第10节','第11节','第12节']}}" value="{{period - 1}}" bindchange="onPeriodChange">
        <view class="form-picker">第{{period}}节 ›</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">类型</text>
      <picker range="{{actionOptions}}" range-key="label" value="{{actionIndex}}" bindchange="onActionChange">
        <view class="form-picker">{{actionOptions[actionIndex].label}} ›</view>
      </picker>
    </view>

    <view class="form-item" wx:if="{{action !== 'cancel'}}">
      <text class="form-label">新科目</text>
      <input class="form-input" placeholder="如:自习" value="{{newSubject}}" bindinput="onSubjectInput" />
    </view>

    <view class="form-item" wx:if="{{action !== 'cancel'}}">
      <text class="form-label">新班级(可选)</text>
      <input class="form-input" placeholder="如:初二1班" value="{{newClassName}}" bindinput="onClassInput" />
    </view>

    <view class="form-item">
      <text class="form-label">备注</text>
      <input class="form-input" placeholder="如:教研会" value="{{note}}" bindinput="onNoteInput" />
    </view>

    <view class="form-actions">
      <t-button theme="default" variant="text" size="medium" bindtap="toggleForm">取消</t-button>
      <t-button theme="primary" size="medium" bindtap="onSave" loading="{{saving}}">保存</t-button>
    </view>
  </view>

  <!-- 调课列表 -->
  <view class="card">
    <view class="card-title">调课记录</view>
    <t-empty wx:if="{{overrides.length === 0 && !loading}}" description="暂无调课" />
    <t-swipe-cell
      wx:for="{{overrides}}"
      wx:key="id"
      right="{{[{text: '删除', className: 'swipe-delete-btn'}]}}"
      bind:click="onDeleteSwipe"
      data-id="{{item.id}}"
    >
      <view class="override-item">
        <view class="override-main">
          <view class="override-header">
            <text class="override-date">{{item.date}}</text>
            <t-tag
              theme="{{item.action === 'cancel' ? 'danger' : item.action === 'change' ? 'warning' : item.action === 'add' ? 'success' : 'default'}}"
              variant="light"
              size="small"
            >
              {{item.action === 'cancel' ? '停课' : item.action === 'change' ? '改科目' : item.action === 'add' ? '加课' : '代课'}}
            </t-tag>
          </view>
          <text class="override-period">第{{item.period}}节</text>
          <text class="override-detail" wx:if="{{item.new_subject}}">→ {{item.new_subject}}</text>
          <text class="override-note" wx:if="{{item.note}}">{{item.note}}</text>
        </view>
      </view>
    </t-swipe-cell>
  </view>
</view>

<t-fab wx:if="{{!showForm}}" icon="add" bind:click="toggleForm" />
