<view class="container" wx:if="{{student}}">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." inherit />

  <block wx:if="{{!loading}}">
    <!-- 学生信息卡 -->
    <view class="card">
      <view class="student-header">
        <view class="avatar {{student.gender === '女' ? 'avatar-female' : 'avatar-male'}}">
          {{student.name[0]}}
        </view>
        <view class="student-basic">
          <text class="student-name">{{student.name}}</text>
          <text class="student-meta">{{student.student_no || '无学号'}} · {{student.gender || ''}}</text>
        </view>
      </view>
      <t-button theme="primary" variant="outline" size="medium" bindtap="showActionSheet" t-class="quick-action-btn">
        + 记考勤 / 请假 / 加扣分
      </t-button>
    </view>

    <!-- 个人备注 -->
    <view class="card">
      <view class="card-title">个人备注</view>
      <view class="note-input-area">
        <textarea
          class="note-textarea"
          placeholder="记录关于这个学生的情况..."
          value="{{noteContent}}"
          bindinput="onNoteInput"
          maxlength="500"
          auto-height
        />
        <t-button theme="primary" size="small" bindtap="saveNote">记录</t-button>
      </view>
      <t-empty wx:if="{{notes.length === 0}}" description="暂无备注" />
      <t-swipe-cell
        wx:for="{{notes}}"
        wx:key="id"
        right="{{[{text: '删除', className: 'swipe-delete-btn'}]}}"
        bind:click="deleteNoteSwipe"
        data-id="{{item.id}}"
      >
        <view class="note-item">
          <text class="note-content">{{item.content}}</text>
          <text class="note-time">{{item.created_at}}</text>
        </view>
      </t-swipe-cell>
    </view>

    <!-- 成绩记录 -->
    <view class="card" wx:if="{{scores.length > 0}}">
      <view class="card-title">成绩记录</view>
      <view wx:for="{{scores}}" wx:key="id" class="score-item">
        <view class="score-info">
          <text class="score-exam">{{item.exam_name}}</text>
          <text class="score-subject">{{item.subject}}</text>
        </view>
        <text class="score-value">{{item.score}}</text>
      </view>
    </view>

    <!-- 记录时间线 -->
    <view class="card">
      <view class="card-title">记录时间线</view>
      <t-empty wx:if="{{records.length === 0}}" description="暂无记录" />
      <t-swipe-cell
        wx:for="{{records}}"
        wx:key="id"
        right="{{[{text: '删除', className: 'swipe-delete-btn'}]}}"
        bind:click="deleteRecordSwipe"
        data-id="{{item.id}}"
      >
        <view class="timeline-item">
          <view class="timeline-dot type-{{item.type}}"></view>
          <view class="timeline-content">
            <view class="timeline-header">
              <t-tag
                theme="{{item.type === 'attendance' ? 'success' : item.type === 'leave' ? 'warning' : 'danger'}}"
                variant="light"
                size="small"
              >
                {{typeLabels[item.type] || item.type}}
              </t-tag>
              <text class="timeline-time">{{item.created_at}}</text>
            </view>
            <text class="timeline-desc">{{item.content || ''}}</text>
            <text class="timeline-value" wx:if="{{item.value !== null && item.value !== undefined}}">
              {{item.value > 0 ? '+' : ''}}{{item.value}}分
            </text>
          </view>
        </view>
      </t-swipe-cell>
    </view>
  </block>
</view>

<!-- 底部弹窗: 快速记录 -->
<view class="action-mask" wx:if="{{showAction}}" bindtap="closeAction"></view>
<view class="action-sheet" wx:if="{{showAction}}">
  <view class="action-title">
    {{actionType === 'attendance' ? '记考勤' : actionType === 'leave' ? '记请假' : '加扣分'}}
    <text class="action-close" bindtap="closeAction">✕</text>
  </view>
  <view class="action-body">
    <view class="form-item" wx:if="{{actionType === 'score'}}">
      <text class="form-label">分数</text>
      <input class="form-input" type="digit" placeholder="正数加分,负数扣分" value="{{actionValue}}" bindinput="onActionValueInput" />
    </view>
    <view class="form-item">
      <text class="form-label">{{actionType === 'leave' ? '事由' : '描述'}}</text>
      <textarea class="form-textarea" placeholder="输入描述..." value="{{actionContent}}" bindinput="onActionContentInput" maxlength="500" auto-height />
    </view>
    <t-button theme="primary" size="large" bindtap="saveAction" loading="{{saving}}" t-class="action-save-btn">
      保存
    </t-button>
  </view>
</view>
