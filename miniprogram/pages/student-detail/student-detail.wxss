.detail-avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.detail-info {
  display: flex;
  flex-direction: column;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.detail-meta {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.quick-action-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.quick-action-circle {
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.sticky-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.note-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.note-item:last-child {
  border-bottom: none;
}

.note-content {
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.6;
  display: block;
  margin-bottom: 4rpx;
}

.note-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.score-item:last-child { border-bottom: none; }

.score-info { display: flex; flex-direction: column; }

.score-exam {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.score-subject {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.score-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #6366F1;
}

/* 底部弹窗 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx;
  z-index: 1001;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.action-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-close {
  font-size: 32rpx;
  color: #9CA3AF;
  font-weight: 400;
}

.action-body {
  margin-top: 8rpx;
}

.action-save-btn {
  width: 100% !important;
  margin-top: 16rpx;
}
