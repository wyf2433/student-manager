<view class="container">
  <t-tabs value="{{filterStatus}}" bindchange="onStatusTabChange" t-class="filter-tabs">
    <t-tab-panel wx:for="{{statusFilters}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" />
  </t-tabs>

  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." inherit />

  <block wx:if="{{!loading}}">
    <view wx:if="{{homework.length === 0}}" class="empty">
      <text class="empty-emoji">📭</text>
      <text>暂无作业</text>
    </view>
    <t-swipe-cell
      wx:for="{{homework}}"
      wx:key="id"
      right="{{[{text: '删除', className: 'swipe-delete-btn'}]}}"
      bind:click="onDeleteSwipe"
      data-id="{{item.id}}"
    >
      <view class="card card-bar {{item.barClass}}">
        <view class="hw-header">
          <view class="color-tag {{item.tagClass}}">
            {{item.emoji}} {{typeLabels[item.type]}}
          </view>
          <view class="color-tag {{item.statusTag}}" bindtap="onStatusChange" data-id="{{item.id}}" data-status="{{item.status}}">
            {{statusLabels[item.status]}} ›
          </view>
        </view>
        <text class="hw-content">{{item.content}}</text>
        <view class="hw-footer">
          <text class="hw-date">🕐 {{item.created_at}}</text>
          <text class="hw-due" wx:if="{{item.due_date}}">⏰ 截止: {{item.due_date}}</text>
          <text class="hw-note" wx:if="{{item.note}}">📝 {{item.note}}</text>
        </view>
      </view>
    </t-swipe-cell>
  </block>
</view>

<view class="fab" bindtap="goAdd">+</view>
