.hw-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.hw-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.hw-content {
  font-size: 30rpx;
  color: #181818;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.hw-footer {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.hw-date {
  font-size: 22rpx;
  color: #BBB;
}

.hw-due {
  font-size: 22rpx;
  color: #FAAD14;
}

.hw-note {
  font-size: 22rpx;
  color: #999;
}

.swipe-delete-btn {
  background: #D54941 !important;
}
