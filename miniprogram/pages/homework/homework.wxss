.filter-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.filter-tab.active {
  background: #3282F0;
  color: #fff;
}

.hw-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.hw-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.hw-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  color: #fff;
}

.type-daily { background: #3282F0; }
.type-experiment_report { background: #52C41A; }
.type-review { background: #722ED1; }
.type-exam { background: #FF4D4F; }

.hw-status {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-active { background: #E6F7FF; color: #3282F0; }
.status-collected { background: #FFF7E6; color: #FAAD14; }
.status-graded { background: #F6FFED; color: #52C41A; }

.hw-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.hw-footer {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.hw-date {
  font-size: 22rpx;
  color: #BBB;
}

.hw-due {
  font-size: 22rpx;
  color: #FAAD14;
}

.hw-note {
  font-size: 22rpx;
  color: #999;
}

.hw-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #FF4D4F;
  padding: 8rpx 20rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #3282F0;
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(50, 130, 240, 0.4);
}

.fab:active {
  background: #2870D0;
}
