.hw-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.hw-content {
  font-size: 30rpx;
  color: #1F2937;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.hw-footer {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.hw-date {
  font-size: 22rpx;
  color: #9CA3AF;
}

.hw-due {
  font-size: 22rpx;
  color: #F59E0B;
  font-weight: 600;
}

.hw-note {
  font-size: 22rpx;
  color: #6B7280;
}
