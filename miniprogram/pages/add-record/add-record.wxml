<view class="container">
  <view class="card">
    <!-- 类型 -->
    <view class="form-item">
      <text class="form-label">类型</text>
      <picker
        range="{{typeOptions}}"
        range-key="label"
        value="{{typeIndex}}"
        bindchange="onTypeChange"
      >
        <view class="form-picker">{{typeOptions[typeIndex].label}} ›</view>
      </picker>
    </view>

    <!-- 班级 -->
    <view class="form-item">
      <text class="form-label">班级</text>
      <picker
        wx:if="{{classes.length > 0}}"
        range="{{classes}}"
        range-key="name"
        value="{{classIndex}}"
        bindchange="onClassChange"
      >
        <view class="form-picker">{{classes[classIndex].name}} ›</view>
      </picker>
      <view wx:else class="form-empty">请先创建班级</view>
    </view>

    <!-- 学生 -->
    <view class="form-item">
      <text class="form-label">学生</text>
      <picker
        wx:if="{{students.length > 0}}"
        range="{{students}}"
        range-key="name"
        value="{{studentIndex}}"
        bindchange="onStudentChange"
      >
        <view class="form-picker">{{students[studentIndex].name}} ›</view>
      </picker>
      <view wx:else class="form-empty">该班暂无学生</view>
    </view>

    <!-- 分数(仅加扣分) -->
    <view class="form-item" wx:if="{{type === 'score'}}">
      <text class="form-label">分数</text>
      <input
        class="form-input"
        type="digit"
        placeholder="正数加分,负数扣分"
        value="{{value}}"
        bindinput="onValueInput"
      />
    </view>

    <!-- 内容 -->
    <view class="form-item">
      <text class="form-label">内容</text>
      <textarea
        class="form-textarea"
        placeholder="输入描述..."
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="500"
      />
    </view>
  </view>

  <view class="btn-primary save-btn {{saving ? 'disabled' : ''}}" bindtap="onSave">
    {{saving ? '保存中...' : '保存'}}
  </view>
</view>
