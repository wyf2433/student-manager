<view class="container">
  <!-- 搜索+日期筛选 -->
  <view class="filter-bar">
    <view class="search-wrap">
      <t-search
        placeholder="🔍 搜索速记内容"
        value="{{keyword}}"
        bind:change="onSearch"
        t-class="search-comp"
      />
    </view>
    <picker mode="date" value="{{filterDate}}" bindchange="onDateChange">
      <view class="date-picker {{filterDate ? 'active' : ''}}">
        <text>{{filterDate ? '📅 ' + filterDate : '📅 日期'}}</text>
      </view>
    </picker>
    <text wx:if="{{filterDate}}" class="clear-date" bindtap="clearDate">✕</text>
  </view>

  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." inherit />

  <block wx:if="{{!loading}}">
    <!-- 速记输入区 -->
    <view class="sticky-note sticky-yellow" wx:if="{{showInput}}">
      <view class="sticky-title">📝 新速记</view>
      <textarea
        class="sticky-note-input"
        placeholder="想到什么就记一笔..."
        value="{{noteContent}}"
        bindinput="onNoteInput"
        maxlength="500"
        auto-height
        focus
      />
      <view class="input-actions">
        <t-button theme="default" variant="text" size="small" bindtap="toggleInput">取消</t-button>
        <t-button theme="primary" size="small" bindtap="saveNote">保存 ✏️</t-button>
      </view>
    </view>

    <!-- 速记列表 -->
    <view wx:if="{{notes.length === 0}}" class="empty">
      <text class="empty-emoji">📝</text>
      <text>暂无速记,快记一笔吧~</text>
    </view>
    <t-swipe-cell
      wx:for="{{notes}}"
      wx:key="id"
      right="{{[{text: '删除', className: 'swipe-delete-btn'}]}}"
      bind:click="onDeleteSwipe"
      data-id="{{item.id}}"
    >
      <view class="sticky-note {{item.stickyClass}}">
        <view class="note-content">{{item.content}}</view>
        <view class="note-footer">
          <text class="note-time">🕐 {{item.created_at}}</text>
        </view>
      </view>
    </t-swipe-cell>
  </block>
</view>

<view class="fab" wx:if="{{!showInput}}" bindtap="toggleInput">+</view>
