.filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.search-wrap {
  flex: 1;
}

.search-comp {
  background: #fff !important;
  border-radius: 12rpx !important;
}

.date-picker {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.date-picker.active {
  background: #ECF2FE;
  color: #0052D9;
}

.clear-date {
  font-size: 28rpx;
  color: #D54941;
  padding: 8rpx;
}

.input-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.note-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.note-content {
  font-size: 30rpx;
  color: #181818;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.note-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.note-time {
  font-size: 22rpx;
  color: #BBB;
}

.swipe-delete-btn {
  background: #D54941 !important;
}
