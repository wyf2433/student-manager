.search-comp {
  background: #fff !important;
  border-radius: 14rpx !important;
}

.date-picker {
  background: #fff;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #6B7280;
  flex-shrink: 0;
  font-weight: 600;
}

.date-picker.active {
  background: #EDE9FE;
  color: #7C3AED;
}

.clear-date {
  font-size: 28rpx;
  color: #EF4444;
  padding: 8rpx;
}

.sticky-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 12rpx;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.note-content {
  font-size: 30rpx;
  color: #1F2937;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.note-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.note-time {
  font-size: 22rpx;
  color: #6B7280;
}
