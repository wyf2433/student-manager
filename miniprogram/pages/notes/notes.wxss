.input-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-cancel {
  padding: 16rpx 32rpx;
  color: #999;
  font-size: 28rpx;
}

.save-btn {
  padding: 16rpx 48rpx;
}

.note-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.note-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.note-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.note-time {
  font-size: 22rpx;
  color: #BBB;
}

.delete-btn {
  font-size: 24rpx;
  color: #FF4D4F;
  padding: 8rpx 20rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #3282F0;
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(50, 130, 240, 0.4);
}

.fab:active {
  background: #2870D0;
}
