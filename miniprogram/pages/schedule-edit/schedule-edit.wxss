.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.form-picker {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.form-input {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.form-textarea {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  min-height: 120rpx;
}

.form-empty {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #BBB;
}

.save-btn {
  margin: 40rpx 0;
}

.save-btn.disabled {
  opacity: 0.6;
}
