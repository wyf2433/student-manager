<view class="container">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." inherit />

  <block wx:if="{{!loading}}">
    <!-- 筛选栏 -->
    <view class="filter-bar">
      <picker
        class="class-picker"
        value="{{classIndex}}"
        range="{{classes}}"
        range-key="name"
        bindchange="onClassChange"
      >
        <view class="picker-text">
          <text>{{classes.length > 0 ? classes[classIndex].name : '选择班级'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
      <view class="add-class-btn" bindtap="addClass">➕</view>
      <view class="search-wrap">
        <t-search
          placeholder="🔍 搜索姓名/学号"
          value="{{keyword}}"
          bind:change="onSearch"
          t-class="search-comp"
        />
      </view>
    </view>

    <!-- 班级人数 -->
    <view class="class-count" wx:if="{{classes.length > 0}}">
      👥 {{classes[classIndex].name}} · {{students.length}}人
    </view>

    <!-- 学生列表 -->
    <view wx:if="{{students.length === 0}}" class="empty">
      <text class="empty-emoji">🧑‍🎓</text>
      <text>暂无学生,点击右下角添加</text>
    </view>
    <view
      wx:for="{{students}}"
      wx:key="id"
      class="student-card"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="avatar-grad avatar-grad-{{item.avatarIdx}}" style="width: 80rpx; height: 80rpx; font-size: 32rpx; margin-right: 24rpx;">
        {{item.name[0]}}
      </view>
      <view class="student-info">
        <view class="student-name-row">
          <text class="student-name">{{item.name}}</text>
          <text class="student-gender">{{item.genderEmoji}}</text>
        </view>
        <text class="student-meta">{{item.student_no || '无学号'}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </block>
</view>

<!-- 底部操作按钮 -->
<view class="bottom-bar">
  <view class="btn-outline success" bindtap="goScoreImport">📊 导入成绩</view>
  <view class="btn-outline info" bindtap="goImport">📥 导入学生</view>
  <view class="fab-inline" bindtap="goAdd">+</view>
</view>

<!-- 新建班级弹窗 -->
<view class="action-mask" wx:if="{{showClassModal}}" bindtap="closeClassModal"></view>
<view class="class-modal" wx:if="{{showClassModal}}">
  <view class="class-modal-title">
    新建班级
    <text class="action-close" bindtap="closeClassModal">✕</text>
  </view>
  <view class="class-modal-body">
    <view class="form-item">
      <text class="form-label">🎓 年级</text>
      <picker range="{{gradeOptions}}" value="{{newGradeIndex}}" bindchange="onGradePick">
        <view class="form-picker">{{gradeOptions[newGradeIndex]}} ›</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">📚 班号</text>
      <picker range="{{classNoOptions}}" value="{{newClassNoIndex}}" bindchange="onClassNoPick">
        <view class="form-picker">{{classNoOptions[newClassNoIndex]}}班 ›</view>
      </picker>
    </view>
    <view class="class-preview">
      班级名称: <text class="class-preview-name">{{gradeOptions[newGradeIndex]}}{{classNoOptions[newClassNoIndex]}}班</text>
    </view>
    <t-button theme="primary" size="large" bindtap="confirmAddClass" t-class="action-save-btn">
      创建
    </t-button>
  </view>
</view>
