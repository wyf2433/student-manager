.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.class-picker {
  flex-shrink: 0;
}

.picker-text {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.search-input {
  flex: 1;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.student-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-male {
  background: #3282F0;
}

.avatar-female {
  background: #FF7A9C;
}

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.student-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.arrow {
  font-size: 40rpx;
  color: #CCC;
}

.bottom-bar {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 20rpx;
}

.btn-import {
  background: #FFF7E6;
  color: #FAAD14;
  border: 2rpx solid #FAAD14;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.btn-score {
  background: #F6FFED;
  color: #52C41A;
  border: 2rpx solid #52C41A;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.fab {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #3282F0;
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(50, 130, 240, 0.4);
}

.fab:active {
  background: #2870D0;
}
