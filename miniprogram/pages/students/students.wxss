.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.class-picker {
  flex-shrink: 0;
}

.picker-text {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #1F2937;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-weight: 600;
}

.picker-arrow {
  font-size: 20rpx;
  color: #9CA3AF;
}

.search-comp {
  background: #fff !important;
  border-radius: 14rpx !important;
}

.student-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.student-card:active {
  background: #F5F7FA;
}

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.student-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
}

.student-gender {
  font-size: 28rpx;
}

.student-meta {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.arrow {
  font-size: 40rpx;
  color: #D1D5DB;
}

.bottom-bar {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
  z-index: 100;
}
