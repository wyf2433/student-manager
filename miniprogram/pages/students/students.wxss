.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.class-picker {
  flex-shrink: 0;
}

.picker-text {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #1F2937;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-weight: 600;
}

.picker-arrow {
  font-size: 20rpx;
  color: #9CA3AF;
}

.add-class-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-class-btn:active {
  opacity: 0.85;
}

.search-comp {
  background: #fff !important;
  border-radius: 14rpx !important;
}

.student-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.student-card:active {
  background: #F5F7FA;
}

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.student-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
}

.student-gender {
  font-size: 28rpx;
}

.student-meta {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.arrow {
  font-size: 40rpx;
  color: #D1D5DB;
}

.bottom-bar {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
  z-index: 100;
}

.fab-inline {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.fab-inline:active {
  opacity: 0.85;
}

/* 新建班级弹窗 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.class-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx;
  z-index: 1001;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.class-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-close {
  font-size: 32rpx;
  color: #9CA3AF;
  font-weight: 400;
}

.class-modal-body {
  margin-top: 8rpx;
}

.class-preview {
  text-align: center;
  font-size: 28rpx;
  color: #6B7280;
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 14rpx;
  margin: 24rpx 0;
}

.class-preview-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #6366F1;
}

.action-save-btn {
  width: 100% !important;
  margin-top: 16rpx;
}
