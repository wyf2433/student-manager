.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.class-picker {
  flex-shrink: 0;
}

.picker-text {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #181818;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.search-wrap {
  flex: 1;
}

.search-comp {
  background: #fff !important;
  border-radius: 12rpx !important;
}

.student-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.student-card:active {
  background: #F5F7FA;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-male { background: #0052D9; }
.avatar-female { background: #FF7A9C; }

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #181818;
}

.student-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.bottom-bar {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 20rpx;
  z-index: 100;
}
