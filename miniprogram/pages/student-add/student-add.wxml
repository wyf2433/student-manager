<view class="container">
  <view class="card">
    <view class="form-item">
      <text class="form-label">班级</text>
      <picker wx:if="{{classes.length > 0}}" range="{{classes}}" range-key="name" value="{{classIndex}}" bindchange="onClassChange">
        <view class="form-picker">{{classes[classIndex].name}} ›</view>
      </picker>
      <view wx:else class="form-empty">请先创建班级</view>
    </view>

    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="学生姓名" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item">
      <text class="form-label">学号(可选)</text>
      <input class="form-input" placeholder="学号" value="{{studentNo}}" bindinput="onNoInput" />
    </view>

    <view class="form-item">
      <text class="form-label">性别</text>
      <radio-group bindchange="onGenderChange">
        <label class="radio-label"><radio value="男" checked="{{gender === '男'}}" />男</label>
        <label class="radio-label"><radio value="女" checked="{{gender === '女'}}" />女</label>
      </radio-group>
    </view>
  </view>

  <view class="btn-primary save-btn {{saving ? 'disabled' : ''}}" bindtap="onSave">
    {{saving ? '保存中...' : '保存'}}
  </view>
</view>
