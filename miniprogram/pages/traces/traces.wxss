.trace-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.trace-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.trace-time {
  font-size: 22rpx;
  color: #BBB;
}

.trace-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #181818;
  display: block;
  margin-bottom: 8rpx;
}

.trace-note {
  font-size: 28rpx;
  color: #666;
  display: block;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.trace-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.trace-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.swipe-delete-btn {
  background: #D54941 !important;
}
