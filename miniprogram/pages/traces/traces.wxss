.trace-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.trace-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.trace-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  display: block;
  margin-bottom: 8rpx;
}

.trace-note {
  font-size: 28rpx;
  color: #6B7280;
  display: block;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.trace-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.trace-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}
