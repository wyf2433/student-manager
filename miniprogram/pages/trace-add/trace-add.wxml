<view class="container">
  <view class="card">
    <!-- 类型 -->
    <view class="form-item">
      <text class="form-label">类型</text>
      <picker range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="form-picker">{{typeOptions[typeIndex].label}} ›</view>
      </picker>
    </view>

    <!-- 标题 -->
    <view class="form-item">
      <text class="form-label">标题</text>
      <input class="form-input" placeholder="留痕标题" value="{{title}}" bindinput="onTitleInput" />
    </view>

    <!-- 备注 -->
    <view class="form-item">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="详细描述..." value="{{note}}" bindinput="onNoteInput" maxlength="1000" auto-height />
    </view>

    <!-- 图片 -->
    <view class="form-item">
      <text class="form-label">图片(最多9张)</text>
      <view class="image-grid">
        <view wx:for="{{images}}" wx:key="*this" class="image-item">
          <image
            class="preview-thumb"
            src="http://47.239.25.178{{item}}"
            mode="aspectFill"
            bindtap="previewImage"
            data-url="{{item}}"
          />
          <view class="image-remove" bindtap="removeImage" data-index="{{index}}">✕</view>
        </view>
        <view class="image-add" bindtap="chooseImage" wx:if="{{images.length < 9}}">
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>
  </view>

  <t-button theme="primary" size="large" bindtap="onSave" loading="{{saving}}" t-class="save-btn">
    {{saving ? '保存中...' : '保存'}}
  </t-button>
</view>
