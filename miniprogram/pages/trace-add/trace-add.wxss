.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.preview-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.image-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #D1D5DB;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F9FAFB;
}

.add-icon {
  font-size: 56rpx;
  color: #D1D5DB;
}

.save-btn {
  margin: 40rpx 0;
  border-radius: 16rpx;
}

.save-btn.disabled {
  opacity: 0.5;
}
