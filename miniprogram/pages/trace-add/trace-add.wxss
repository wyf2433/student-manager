.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.form-picker {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.form-input {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.form-textarea {
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  min-height: 120rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.preview-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.image-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #CCC;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 56rpx;
  color: #CCC;
}

.save-btn {
  margin: 40rpx 0;
}

.save-btn.disabled {
  opacity: 0.6;
}
