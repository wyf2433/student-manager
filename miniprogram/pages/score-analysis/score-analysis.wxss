.exam-item {
  margin-bottom: 16rpx;
}

.exam-item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.exam-emoji {
  font-size: 44rpx;
}

.exam-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.exam-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
}

.exam-desc {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.exam-arrow {
  font-size: 36rpx;
  color: #C7D2FE;
}

.save-btn {
  margin-top: 40rpx;
  border-radius: 16rpx;
}
