page {
  background-color: #F5F7FA;
  font-size: 28rpx;
  color: #181818;
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* TDesign 主题色覆盖 */
:root {
  --td-brand-color: #0052D9;
  --td-brand-light: #ECF2FE;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #181818;
  margin-bottom: 16rpx;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-more {
  font-size: 24rpx;
  color: #0052D9;
}

/* 按钮 */
.btn-primary {
  background: #0052D9;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
}

.btn-primary:active {
  background: #003CAB;
}

.btn-primary.disabled {
  opacity: 0.5;
}

/* 空状态 */
.empty {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 26rpx;
}

/* 删除按钮 */
.delete-btn {
  font-size: 24rpx;
  color: #D54941;
  padding: 8rpx 20rpx;
}

/* FAB */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #0052D9;
  color: #fff;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.35);
  z-index: 100;
}

.fab:active {
  background: #003CAB;
}

/* 底部按钮组 */
.bottom-bar {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 20rpx;
  z-index: 100;
}

.btn-outline {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: 2rpx solid;
  background: #fff;
}

.btn-outline.warn {
  color: #ED7B2F;
  border-color: #ED7B2F;
}

.btn-outline.success {
  color: #2BA471;
  border-color: #2BA471;
}

/* 表单 */
.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.form-picker {
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #181818;
}

.form-input {
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.form-textarea {
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  min-height: 120rpx;
}

.form-empty {
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #BBB;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.filter-tab.active {
  background: #0052D9;
  color: #fff;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.date-picker {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.date-picker.active {
  background: #ECF2FE;
  color: #0052D9;
}

.clear-date {
  font-size: 28rpx;
  color: #D54941;
  padding: 8rpx;
}

/* 保存按钮 */
.save-btn {
  margin: 40rpx 0;
}

.save-btn.disabled {
  opacity: 0.5;
}

.btn-cancel-text {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 20rpx;
}

.btn-cancel {
  padding: 16rpx 32rpx;
  color: #999;
  font-size: 28rpx;
}
